# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/medisync"

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="your-secret-here-min-32-chars"
BETTER_AUTH_URL="https://medisync.app"          # public base URL (no trailing slash)

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="MediSync <noreply@medisync.app>"    # must be a verified Resend domain

# ── MediSync Cron / Notification Service ─────────────────────────────────────
# A strong random secret used to authenticate inbound cron job requests.
# The application CANNOT process notifications without this key.
# Generate one with: openssl rand -hex 32
MEDISYNC_PRIVATE_KEY="change-me-generate-with-openssl-rand-hex-32"

# ── Groq (AI Chat) ───────────────────────────────────────────────────────────
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
